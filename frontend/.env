# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# MongoDB Atlas Connection
# Replace <cluster-hostname> with your actual cluster hostname (e.g., cluster0.xxxxx.mongodb.net)
MONGODB_URI=mongodb+srv://bytemaster000_db_user:RsnYqpn5RQmYZ9Pu@cluster0.tbxlzjt.mongodb.net/yolo_crowd?retryWrites=true&w=majority

# JWT Secret for session tokens
JWT_SECRET=yolo-crowd-jwt-secret-change-in-production

# Default admin credentials (seeded on first startup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=password
DEFAULT_ADMIN_NAME=Admin User
